# mammamiradio environment configuration
# Copy to .env and fill in your values: cp .env.example .env

# Server bind address and port (defaults work for local dev)
MAMMAMIRADIO_BIND_HOST=127.0.0.1
MAMMAMIRADIO_PORT=8000

# Admin credentials (required when binding to non-localhost)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Spotify Web API (enables playlist browsing and metadata)
# Create an app at https://developer.spotify.com/dashboard
# Set redirect URI to http://127.0.0.1:8000/spotify/callback for local dev
# Or set MAMMAMIRADIO_SPOTIFY_REDIRECT_BASE_URL=https://radio.example.com and
# register https://radio.example.com/spotify/callback instead.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
MAMMAMIRADIO_SPOTIFY_REDIRECT_BASE_URL=

# Anthropic API key (enables AI-generated banter and ads)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key (enables gpt-4o-mini-tts voice for hosts with engine = "openai")
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Home Assistant (optional — lets hosts reference your smart home state)
# HA_TOKEN=
# HA_URL=http://homeassistant.local:8123

# Override Claude model (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=

# Enable yt-dlp fallback for demo tracks (disabled by default for copyright safety)
# MAMMAMIRADIO_ALLOW_YTDLP=true
